# lsts_completion <path> <line> <character> [snapshot-file]
lsts_completion() {
    local path="$1" line="$2" character="$3" expected="${4:-}"
    local uri="file://$LSTS_ROOT/$path"
    _lsts_doc_request "textDocument/completion" "$path" \
        "{\"textDocument\":{\"uri\":\"${uri}\"},\"position\":{\"line\":${line},\"character\":${character}},\"context\":{\"triggerKind\":1}}" \
        "$expected"
}

# lsts_references <path> <line> <character> [include-declaration:true|false] [snapshot-file]
lsts_references() {
    local path="$1" line="$2" character="$3"
    local include_decl="${4:-true}"
    local expected="${5:-}"
    local uri="file://$LSTS_ROOT/$path"
    _lsts_doc_request "textDocument/references" "$path" \
        "{\"textDocument\":{\"uri\":\"${uri}\"},\"position\":{\"line\":${line},\"character\":${character}},\"context\":{\"includeDeclaration\":${include_decl}}}" \
        "$expected"
}

