# lsts_formatting <path> [tab-size] [insert-spaces] [snapshot-file]
lsts_formatting() {
    local path="$1"
    local tab_size="${2:-4}"
    local insert_spaces="${3:-true}"
    local expected="${4:-}"
    local uri="file://$LSTS_ROOT/$path"
    _lsts_doc_request "textDocument/formatting" "$path" \
        "{\"textDocument\":{\"uri\":\"${uri}\"},\"options\":{\"tabSize\":${tab_size},\"insertSpaces\":${insert_spaces}}}" \
        "$expected"
}

