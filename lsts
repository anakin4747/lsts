#!/usr/bin/env bash

# lsts_set_cmd <command>
# Set the command used to start the language server under test.
lsts_set_cmd() {
    [[ $# == 1 ]] || {
        echo "lsts_set_cmd requires the command to start the target language server"
        exit 1
    }
    ls="$(echo "$1" | awk '{print $1}')"
    command -v "$ls" > /dev/null || {
        echo "lsts_set_cmd cannot find the target language server: '$ls'"
        exit 1
    }
    LSTS_CMD="$1"
}

# lsts_set_root <directory>
# Set the workspace root directory passed to the language server as rootUri.
lsts_set_root() {
    [[ $# == 1 ]] || {
        echo "lsts_set_root requires a root directory for specifying workspaceFolders"
        exit 1
    }
    LSTS_ROOT="$1"
}

# lsts_set_langId <language-id>
# Set the LSP language identifier sent in textDocument/didOpen notifications.
lsts_set_langId() {
    [[ $# == 1 ]] || {
        echo "lsts_set_langId requires the language identifier"
        exit 1
    }
    LSTS_LANG_ID="$1"
}

_LSTS_ID=0

# lsts_send <body>
# Write a JSON-RPC message with a Content-Length header to the language server.
lsts_send() {
    local body="$1"
    local len
    len="$(printf '%s' "$body" | wc -c)"
    printf "Content-Length: %d\r\n\r\n%s" "$len" "$body" >&"$LSTS_WRITE_FD"
}

# lsts_recv
# Read one JSON-RPC message from the language server into LSTS_RESPONSE.
lsts_recv() {
    local line content_length=0 raw

    while IFS= read -r -t "${LSTS_TIMEOUT:-10}" line <&"$LSTS_READ_FD"; do
        line="${line%$'\r'}"
        [[ -z "$line" ]] && break
        if [[ "$line" =~ ^Content-Length:\ ([0-9]+)$ ]]; then
            content_length="${BASH_REMATCH[1]}"
        fi
    done

    [[ "$content_length" -eq 0 ]] && {
        echo "lsts_recv: no Content-Length header received" >&2
        return 1
    }

    IFS= read -r -N "$content_length" -t "${LSTS_TIMEOUT:-10}" raw <&"$LSTS_READ_FD"

    LSTS_RESPONSE="$(printf '%s' "$raw" | tr '\t\n' '  ')"
}

# lsts_recv_response
# Read messages until a JSON-RPC response (has "id", no "method") is received,
# auto-replying to any server-to-client requests encountered along the way.
lsts_recv_response() {
    while true; do
        lsts_recv || return 1
        # Server-to-client requests have both "id" and "method". Reply with an
        # empty result so the server can continue, then keep waiting.
        if printf '%s' "$LSTS_RESPONSE" | \
                jq -e 'has("id") and has("method")' >/dev/null 2>&1; then
            local req_id
            req_id="$(printf '%s' "$LSTS_RESPONSE" | jq -r '.id')"
            lsts_send "{\"jsonrpc\":\"2.0\",\"id\":${req_id},\"result\":null}"
            continue
        fi
        # A proper response has "id" but no "method".
        printf '%s' "$LSTS_RESPONSE" | jq -e 'has("id")' >/dev/null 2>&1 && return 0
    done
}

# lsts_request <method> <params-json>
# Send a JSON-RPC request with an auto-incremented id.
lsts_request() {
    local method="$1" params="$2"
    _LSTS_ID=$((_LSTS_ID + 1))
    lsts_send "{\"jsonrpc\":\"2.0\",\"id\":${_LSTS_ID},\"method\":\"${method}\",\"params\":${params}}"
}

# lsts_notify <method> <params-json>
# Send a JSON-RPC notification (no id, no response expected).
lsts_notify() {
    local method="$1" params="$2"
    lsts_send "{\"jsonrpc\":\"2.0\",\"method\":\"${method}\",\"params\":${params}}"
}

# lsts_start
# Start the language server as a coprocess and open read/write file descriptors.
lsts_start() {
    : "${LSTS_CMD:?language server command not set. use lsts_set_cmd to set the command to start the target language server}"
    : "${LSTS_ROOT:?root directory not set. use lsts_set_root to set the root directory}"
    : "${LSTS_LANG_ID:?language Id not set. use lsts_set_langId to set the language Id}"

    cd "$LSTS_ROOT" || return 1

    _LSTS_ID=0
    coproc LSTS { ${LSTS_CMD}; }
    LSTS_READ_FD=${LSTS[0]}
    LSTS_WRITE_FD=${LSTS[1]}
}

# lsts_stop
# Gracefully shut down the language server and reap the coprocess.
lsts_stop() {
    lsts_notify "exit" "{}" 2>/dev/null || true
    kill "${LSTS_PID:-}" 2>/dev/null || true
    wait "${LSTS_PID:-}" 2>/dev/null || true
}

# lsts_initialize
# Send the LSP initialize/initialized handshake and verify the server responded
# with capabilities.
lsts_initialize() {
    lsts_request "initialize" \
        "{\"processId\":null,\"rootUri\":\"file://${LSTS_ROOT}\",\"rootPath\":\"${LSTS_ROOT}\",\"capabilities\":{\"window\":{\"workDoneProgress\":true}}}"
    lsts_recv_response

    # Fail fast if the server returned a JSON-RPC error.
    local err
    err="$(echo "$LSTS_RESPONSE" | jq -r '.error')"
    [[ "$err" == "null" ]] || {
        echo "lsts_initialize: server returned error: $err" >&2
        return 1
    }

    lsts_notify "initialized" "{}"

    echo "$LSTS_RESPONSE" | jq -e '.result.capabilities | objects' > /dev/null
}

# lsts_open <relative-path>
# Opens a document and sends textDocument/didOpen. Requires lsts_initialize
# to have been called first.
lsts_open() {
    local path="$1"
    local uri="file://$LSTS_ROOT/$path"
    local text
    text="$(jq -Rs . <"$LSTS_ROOT/$path")"

    lsts_notify "textDocument/didOpen" \
        "{\"textDocument\":{\"uri\":\"${uri}\",\"languageId\":\"${LSTS_LANG_ID}\",\"version\":1,\"text\":${text}}}"
}

# _lsts_fixture_or_print [fixture-path]
# Diff LSTS_RESPONSE against fixture-path, or print it (snapshot mode) if omitted.
_lsts_fixture_or_print() {
    local fixture="${1:-}"
    if [[ -z "$fixture" ]]; then
        printf "\e[01;33mWARNING: snapshot mode\e[0m\n" >&3
        echo "$LSTS_RESPONSE"
        return
    fi
    diff <(echo "$LSTS_RESPONSE") "$fixture"
}

# _lsts_doc_request <method> <path> <params-json> [fixture-path]
# Internal helper: initialize, open, send a request with caller-supplied
# params, then fixture-or-print.
_lsts_doc_request() {
    local method="$1" path="$2" params="$3" fixture="${4:-}"

    lsts_initialize
    lsts_open "$path"
    lsts_request "$method" "$params"
    lsts_recv_response

    _lsts_fixture_or_print "$fixture"
}

# _lsts_pos_request <method> <path> <line> <character> [fixture-path]
# Internal helper for position-based requests.
_lsts_pos_request() {
    local method="$1" path="$2" line="$3" character="$4" fixture="${5:-}"
    local uri="file://$LSTS_ROOT/$path"

    _lsts_doc_request "$method" "$path" \
        "{\"textDocument\":{\"uri\":\"${uri}\"},\"position\":{\"line\":${line},\"character\":${character}}}" \
        "$fixture"
}

