# lsts_rename <path:line:col> <new-name> [fixture-path]
# Accepts 1-based line and column.
lsts_rename() {
    local input="$1" new_name="$2" fixture="${3:-}"
    local path line character
    _lsts_parse_pos "$input" path line character
    local uri="file://$LSTS_ROOT/$path"
    _lsts_doc_request "textDocument/rename" "$path" \
        "{\"textDocument\":{\"uri\":\"${uri}\"},\"position\":{\"line\":${line},\"character\":${character}},\"newName\":\"${new_name}\"}" \
        "$fixture"
}

# lsts_code_action <path:start-line:start-col:end-line:end-col> [fixture-path]
# Accepts 1-based line and column values for both range endpoints.
lsts_code_action() {
    local input="$1" fixture="${2:-}"
    local path sl sc el ec
    IFS=: read -r path sl sc el ec <<< "$input"
    sl=$((sl - 1)); sc=$((sc - 1))
    el=$((el - 1)); ec=$((ec - 1))
    local uri="file://$LSTS_ROOT/$path"
    _lsts_doc_request "textDocument/codeAction" "$path" \
        "{\"textDocument\":{\"uri\":\"${uri}\"},\"range\":{\"start\":{\"line\":${sl},\"character\":${sc}},\"end\":{\"line\":${el},\"character\":${ec}}},\"context\":{\"diagnostics\":[]}}" \
        "$fixture"
}

# lsts_call_hierarchy_prepare <path:line:col> [fixture-path]
# Accepts 1-based line and column. Sends textDocument/prepareCallHierarchy and
# stores the first item in LSTS_CALL_HIERARCHY_ITEM for use with
# lsts_incoming_calls / lsts_outgoing_calls.
lsts_call_hierarchy_prepare() {
    local input="$1" fixture="${2:-}"
    _lsts_pos_request "textDocument/prepareCallHierarchy" "$input" "$fixture"
    LSTS_CALL_HIERARCHY_ITEM="$(printf '%s' "$LSTS_RESPONSE" | jq -c '.result[0]')"
}

# lsts_incoming_calls <item-json> [fixture-path]
# Sends callHierarchy/incomingCalls for the given CallHierarchyItem.
# Requires lsts_initialize and lsts_open to have been called already.
lsts_incoming_calls() {
    local item="$1" fixture="${2:-}"
    lsts_request "callHierarchy/incomingCalls" "{\"item\":${item}}"
    lsts_recv_response
    _lsts_fixture_or_print "$fixture"
}

# lsts_outgoing_calls <item-json> [fixture-path]
# Sends callHierarchy/outgoingCalls for the given CallHierarchyItem.
# Requires lsts_initialize and lsts_open to have been called already.
lsts_outgoing_calls() {
    local item="$1" fixture="${2:-}"
    lsts_request "callHierarchy/outgoingCalls" "{\"item\":${item}}"
    lsts_recv_response
    _lsts_fixture_or_print "$fixture"
}

# _lsts_prepare_call_hierarchy <path:line:col>
# Internal helper: initialize, open, and run prepareCallHierarchy silently.
# Accepts 1-based line and column. Stores the first CallHierarchyItem in
# LSTS_CALL_HIERARCHY_ITEM.
_lsts_prepare_call_hierarchy() {
    local input="$1"
    local path line character
    _lsts_parse_pos "$input" path line character
    local uri="file://$LSTS_ROOT/$path"
    lsts_initialize
    lsts_open "$path"
    lsts_request "textDocument/prepareCallHierarchy" \
        "{\"textDocument\":{\"uri\":\"${uri}\"},\"position\":{\"line\":${line},\"character\":${character}}}"
    lsts_recv_response
    LSTS_CALL_HIERARCHY_ITEM="$(printf '%s' "$LSTS_RESPONSE" | jq -c '.result[0]')"
}

# lsts_goto_incoming_calls <path:line:col> [fixture-path]
# Full two-step helper: prepareCallHierarchy then incomingCalls.
# Accepts 1-based line and column.
lsts_goto_incoming_calls() {
    local input="$1" fixture="${2:-}"
    _lsts_prepare_call_hierarchy "$input"
    lsts_incoming_calls "$LSTS_CALL_HIERARCHY_ITEM" "$fixture"
}

# lsts_goto_outgoing_calls <path:line:col> [fixture-path]
# Full two-step helper: prepareCallHierarchy then outgoingCalls.
# Accepts 1-based line and column.
lsts_goto_outgoing_calls() {
    local input="$1" fixture="${2:-}"
    _lsts_prepare_call_hierarchy "$input"
    lsts_outgoing_calls "$LSTS_CALL_HIERARCHY_ITEM" "$fixture"
}

# _lsts_recv_notification <method>
# Read messages until a notification with the given method is received,
# auto-replying to any server-to-client requests along the way.
# Aborts with an error if no matching notification arrives within LSTS_TIMEOUT
# seconds (default 10). Stores the notification in LSTS_RESPONSE.
_lsts_recv_notification() {
    local target_method="$1"
    local _timeout="${LSTS_TIMEOUT:-10}"
    local _deadline=$(( SECONDS + _timeout ))
    while (( SECONDS < _deadline )); do
        lsts_recv || return 1
        _lsts_reply_to_request && continue
        # Notifications have no "id". Check if the method matches.
        printf '%s' "$LSTS_RESPONSE" | \
            jq -e --arg m "$target_method" \
                'has("method") and .method == $m' >/dev/null 2>&1 && return 0
    done
    echo "_lsts_recv_notification: timed out after ${_timeout}s waiting for ${target_method}" >&2
    return 1
}

# lsts_diagnostics <path> [fixture-path]
# Initialize, open a document, and wait for the server's
# textDocument/publishDiagnostics notification for that file.
# Fails if no diagnostics notification arrives within LSTS_TIMEOUT seconds,
# or if the notification contains an empty diagnostics array.
lsts_diagnostics() {
    local path="$1" fixture="${2:-}"
    local uri="file://$LSTS_ROOT/$path"

    lsts_initialize
    lsts_open "$path"

    # Consume messages until we get publishDiagnostics for our file.
    local _timeout="${LSTS_TIMEOUT:-10}"
    local _deadline=$(( SECONDS + _timeout ))
    while (( SECONDS < _deadline )); do
        lsts_recv || return 1
        _lsts_reply_to_request && continue
        printf '%s' "$LSTS_RESPONSE" | jq -e \
            --arg m "textDocument/publishDiagnostics" --arg uri "$uri" \
            '.method == $m and .params.uri == $uri' >/dev/null 2>&1 && break
    done

    # Require at least one diagnostic — an empty array means no errors were
    # reported, which indicates the file under test has no syntax errors.
    printf '%s' "$LSTS_RESPONSE" | \
        jq -e '.params.diagnostics | length > 0' >/dev/null 2>&1 || {
        echo "lsts_diagnostics: server reported no diagnostics for $path" >&2
        return 1
    }

    _lsts_fixture_or_print "$fixture"
}

# lsts_initialize_capability <jq-expr>
# Initialize and assert that the server's capabilities satisfy <jq-expr>.
# The expression is evaluated against the full initialize response; use
# .result.capabilities to navigate to capability fields.
#
#   lsts_initialize_capability '.result.capabilities.hoverProvider == true'
#   lsts_initialize_capability '.result.capabilities.textDocumentSync.change == 1'
lsts_initialize_capability() {
    local expr="$1"
    lsts_initialize
    echo "$LSTS_RESPONSE" | jq -e "$expr" > /dev/null
}

# lsts_diagnostics_none <path> [fixture-path]
# Initialize, open a document, and wait for the server's
# textDocument/publishDiagnostics notification for that file.
# Fails if no notification arrives within LSTS_TIMEOUT seconds,
# or if the notification contains any diagnostics (i.e. the document is
# expected to be error-free).
lsts_diagnostics_none() {
    local path="$1" fixture="${2:-}"
    local uri="file://$LSTS_ROOT/$path"

    lsts_initialize
    lsts_open "$path"

    local _timeout="${LSTS_TIMEOUT:-10}"
    local _deadline=$(( SECONDS + _timeout ))
    while (( SECONDS < _deadline )); do
        lsts_recv || return 1
        _lsts_reply_to_request && continue
        printf '%s' "$LSTS_RESPONSE" | jq -e \
            --arg m "textDocument/publishDiagnostics" --arg uri "$uri" \
            '.method == $m and .params.uri == $uri' >/dev/null 2>&1 && break
    done

    printf '%s' "$LSTS_RESPONSE" | \
        jq -e '.params.diagnostics | length == 0' >/dev/null 2>&1 || {
        echo "lsts_diagnostics_none: server reported diagnostics for $path" >&2
        return 1
    }

    _lsts_fixture_or_print "$fixture"
}
