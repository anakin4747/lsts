# lsts_formatting <path> [tab-size] [insert-spaces] [fixture-path]
lsts_formatting() {
    local path="$1" tab_size="${2:-4}" insert_spaces="${3:-true}" fixture="${4:-}"
    local uri="file://$LSTS_ROOT/$path"
    _lsts_doc_request "textDocument/formatting" "$path" \
        "{\"textDocument\":{\"uri\":\"${uri}\"},\"options\":{\"tabSize\":${tab_size},\"insertSpaces\":${insert_spaces}}}" \
